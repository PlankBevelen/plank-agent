PLANK_LLM_API_KEY=
PLANK_LLM_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
PLANK_LLM_MODEL=deepseek-v3-2-251201

SERPAPI_KEY=

PLANK_EMBEDDING_MODEL_PATH=./models/paraphrase-multilingual-MiniLM-L12-v2
PLANK_EMBEDDING_DEVICE=cpu

PLANK_REACT_MAX_STEPS=5
PLANK_CONTEXT_MAX_CHARS=5000
PLANK_CONTEXT_MAX_HISTORY_TURNS=4
PLANK_CONTEXT_MAX_KB_ITEMS=3
PLANK_CONTEXT_MAX_MEMORY_ITEMS=4

PLANK_MEMORY_WRITE_ENABLED=true
PLANK_MEMORY_DB_PATH=./chroma_db
PLANK_MEMORY_COLLECTION=agent_memory
PLANK_MEMORY_TOP_K=6
PLANK_MEMORY_THRESHOLD=0.65

PLANK_KB_QUERY_CACHE_MAX_SIZE=1024
PLANK_KB_QUERY_CACHE_TTL_SECONDS=3600

PLANK_AGENT_PREWARM=true
PLANK_WEB_INCLUDE_MEMORY=true
PLANK_WEB_PERSIST_MEMORY=true

PLANK_SESSION_BACKEND=memory
PLANK_SESSION_TTL_SECONDS=1800
PLANK_SESSION_CLEANUP_INTERVAL_SECONDS=300
PLANK_SESSION_KEY_PREFIX=plank-agent:session
PLANK_SESSION_LOCK_TIMEOUT_SECONDS=30
PLANK_SESSION_LOCK_BLOCKING_TIMEOUT_SECONDS=15

PLANK_RATE_LIMIT_BACKEND=memory
PLANK_RATE_LIMIT_WINDOW_SECONDS=60
PLANK_RATE_LIMIT_CLEANUP_INTERVAL_SECONDS=300
PLANK_SESSION_RATE_LIMIT_MAX_REQUESTS=20
PLANK_IP_RATE_LIMIT_MAX_REQUESTS=100
PLANK_SESSION_RATE_LIMIT_PREFIX=plank-agent:ratelimit:session
PLANK_IP_RATE_LIMIT_PREFIX=plank-agent:ratelimit:ip

PLANK_REDIS_URL=redis://localhost:6379/0
